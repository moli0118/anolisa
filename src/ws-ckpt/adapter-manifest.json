{
  "schemaVersion": "1",
  "component": "ws-ckpt",
  "version": "0.4.0",
  "description": "Workspace session snapshot and recovery skill for agent runtimes.",
  "targets": {
    "openclaw": {
      "compatibleVersions": "",
      "capabilities": {
        "plugins": [
          "ws-ckpt"
        ],
        "skills": [],
        "commands": [],
        "hooks": []
      },
      "actions": {
        "detect":    "openclaw/detect-openclaw.sh",
        "install":   "openclaw/install-openclaw.sh",
        "uninstall": "openclaw/uninstall-openclaw.sh"
      }
    },
    "hermes": {
      "compatibleVersions": "",
      "capabilities": {
        "plugins": [
          "ws-ckpt"
        ],
        "skills": [],
        "commands": [],
        "hooks": []
      },
      "actions": {
        "detect":    "hermes/detect-hermes.sh",
        "install":   "hermes/install-hermes.sh",
        "uninstall": "hermes/uninstall-hermes.sh"
      }
    }
  },
  "resources": {
    "binary": {
      "source": "src/target/release/ws-ckpt",
      "stagePath": "target/bin/ws-ckpt",
      "installPath": "/usr/local/bin/ws-ckpt"
    },
    "skill": {
      "source": "src/skills/ws-ckpt",
      "stagePath": "target/share/anolisa/runtime/skills/ws-ckpt",
      "installPath": "/usr/share/anolisa/runtime/skills/ws-ckpt",
      "openclawPath": "~/.openclaw/skills/ws-ckpt",
      "hermesPath": "~/.hermes/skills/ws-ckpt"
    },
    "plugin": {
      "source": "src/plugins",
      "stagePath": "target/share/anolisa/runtime/ws-ckpt/plugins",
      "installPath": "/usr/share/anolisa/runtime/ws-ckpt/plugins"
    },
    "systemd": {
      "source": "src/systemd/ws-ckpt.service",
      "stagePath": "target/lib/systemd/system/ws-ckpt.service",
      "installPath": "/usr/lib/systemd/system/ws-ckpt.service"
    }
  }
}
